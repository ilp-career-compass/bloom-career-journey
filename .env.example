# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# MSG91 OTP Widget (https://msg91.com/otp)
# Widget ID and Token Auth from MSG91 dashboard → OTP Widget
VITE_MSG91_WIDGET_ID=your-msg91-widget-id
VITE_MSG91_TOKEN_AUTH=your-msg91-token-auth

# Sarvam streaming STT proxy (optional — defaults to ws://127.0.0.1:8000/ws/stream)
VITE_SARVAM_PROXY_URL=ws://127.0.0.1:8000/ws/stream

# Azure Speech fallback (optional)
VITE_AZURE_SPEECH_KEY=your-azure-speech-key
VITE_AZURE_SPEECH_REGION=eastus

# Audio response feature flags (optional — all enabled by default)
VITE_ENABLE_AUDIO_RESPONSES=true
VITE_AUDIO_ENABLE_OFFLINE_MODE=true
VITE_AUDIO_ENABLE_TRANSCRIPTION=true
VITE_AUDIO_MAX_DURATION=120000
VITE_AUDIO_CHUNK_SIZE=524288

# Google Sheets sync (server-side scripts only, not Vite)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEET_ID=your-google-sheet-id
